# Docker Compose host ports
BACKEND_PORT=5001
FRONTEND_PORT=3000

# Browser-facing backend URL used by the React dev server
REACT_APP_API_BASE_URL=http://localhost:5001

# Host path to the SSH private key used for the database tunnel.
# Compose exposes this file to the backend at /run/secrets/ec2_ssh_key.
EC2_SSH_KEY_HOST_PATH=/absolute/path/to/ec2-ssh-key.pem

# Backend SSH tunnel settings
EC2_HOST=ec2.example.com
EC2_USER=ec2-user

# Backend database settings
DB_HOST=database.example.com
DB_USER=trivia_user
DB_PASSWORD=change-me
DB_NAME=trivia_db
